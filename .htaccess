# Принудительный редирект на канонический HTTPS-хост
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} !^zamok-i\.ru$ [NC]
    RewriteRule ^ https://zamok-i.ru%{REQUEST_URI} [R=301,L]
</IfModule>

# Явные MIME-типы для корректного Content-Type
AddType text/html .html .htm
AddType application/json .json
AddType application/xml .xml
AddType application/manifest+json .webmanifest
AddType image/svg+xml .svg .svgz

# SEO 301 редиректы для дублирующихся страниц (консолидация)
# Кластер: Замена замков
Redirect 301 /service/zamena/zamena-zamka-vhodnoy-dveri.html https://zamok-i.ru/service/zamena/zamena-zamka-dveri.html
Redirect 301 /service/zamena/zamena-dvernyh-zamkov.html https://zamok-i.ru/service/zamena/zamena-zamka-dveri.html
Redirect 301 /service/zamena/zamena-zamkov-spb.html https://zamok-i.ru/service/zamena/zamena-zamka-dveri.html
Redirect 301 /service/master-zamene-dvernyh.html https://zamok-i.ru/service/zamena/zamena-zamka-dveri.html

# Кластер: Вскрытие замков
Redirect 301 /service/vskrytie/vskrytie-zamkov-kvartire.html https://zamok-i.ru/service/vskrytie/avariynoe-vskrytie-zamkov.html
Redirect 301 /service/vyzvat-mastera-vskrytiyu.html https://zamok-i.ru/service/vskrytie/avariynoe-vskrytie-zamkov.html
Redirect 301 /service/sluzhba-vskrytiyu-zamkov.html https://zamok-i.ru/service/vskrytie/avariynoe-vskrytie-zamkov.html

# Кластер: Ремонт замков
Redirect 301 /service/remont/remont-zamka-vhodnoy.html https://zamok-i.ru/service/remont/remont-zamkov-dvernyh.html
Redirect 301 /service/remont/masterskaya-remontu-zamkov.html https://zamok-i.ru/service/remont/remont-zamkov-dvernyh.html

# Старые редиректы
Redirect 301 /service/zamena/pomenyat-zamok-vhodnoy.html https://zamok-i.ru/service/zamena/zamena-zamka-dveri.html

# Защита от clickjacking - запрет на отображения сайта в iframe
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Content-Security-Policy для защиты от XSS
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.unsplash.com data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
    # Запрет MIME-sniffing для защиты от подмены типа контента
    Header always set X-Content-Type-Options "nosniff"
    # HSTS - принудительное использование HTTPS (1 год)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Явно дублируем CSP и базовые security headers на статике,
    # чтобы хостинг не отдавал css/js/webp без этих заголовков.
    <FilesMatch "\.(?:css|js|mjs|json|xml|svg|gif|png|jpe?g|webp|ico|woff2?|ttf)$">
        Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.unsplash.com data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
        Header always set X-Frame-Options "SAMEORIGIN"
        Header always set X-Content-Type-Options "nosniff"
        Header always set Referrer-Policy "strict-origin-when-cross-origin"
        Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    </FilesMatch>
</IfModule>
