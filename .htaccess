# Принудительный редирект с HTTP на HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# SEO 301 редиректы для дублирующихся страниц (консолидация)
# Кластер: Замена замков
Redirect 301 /service/zamena/zamena-zamka-vhodnoy-dveri.html /service/zamena/zamena-zamka-dveri.html
Redirect 301 /service/zamena/zamena-dvernyh-zamkov.html /service/zamena/zamena-zamka-dveri.html
Redirect 301 /service/zamena/zamena-zamkov-spb.html /service/zamena/zamena-zamka-dveri.html
Redirect 301 /service/master-zamene-dvernyh.html /service/zamena/zamena-zamka-dveri.html

# Кластер: Вскрытие замков
Redirect 301 /service/vskrytie/vskrytie-zamkov-kvartire.html /service/vskrytie/avariynoe-vskrytie-zamkov.html
Redirect 301 /service/vyzvat-mastera-vskrytiyu.html /service/vskrytie/avariynoe-vskrytie-zamkov.html
Redirect 301 /service/sluzhba-vskrytiyu-zamkov.html /service/vskrytie/avariynoe-vskrytie-zamkov.html

# Кластер: Ремонт замков
Redirect 301 /service/remont/remont-zamka-vhodnoy.html /service/remont/remont-zamkov-dvernyh.html
Redirect 301 /service/remont/masterskaya-remontu-zamkov.html /service/remont/remont-zamkov-dvernyh.html

# Старые редиректы
Redirect 301 /service/zamena/pomenyat-zamok-vhodnoy.html /service/zamena/zamena-zamka-vhodnoy-dveri.html

# Защита от clickjacking - запрет на отображения сайта в iframe
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Content-Security-Policy для защиты от XSS
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.unsplash.com data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
    # Запрет MIME-sniffing для защиты от подмены типа контента
    Header always set X-Content-Type-Options "nosniff"
    # HSTS - принудительное использование HTTPS (1 год)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
